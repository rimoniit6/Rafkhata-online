# Database
DATABASE_URL=postgresql://user:password@host:5432/database
DIRECT_URL=postgresql://user:password@host:5432/database

# Supabase (public — safe to expose)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase (secret — NEVER commit, NEVER share)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# UploadThing
UPLOADTHING_SECRET=your-uploadthing-secret
UPLOADTHING_APP_ID=your-app-id
UPLOADTHING_TOKEN=your-token

# Auth
CSRF_SECRET=a-random-string-at-least-32-characters-long

# Rate Limiting (Upstash)
UPSTASH_REDIS_REST_URL=https://your-region.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Seed defaults (optional — override for production seeding)
# SUPER_ADMIN_EMAIL=admin@localhost
# SUPER_ADMIN_PASSWORD=ChangeMe123!
# ADMIN_EMAIL=moderator@shikhabangla.com
# ADMIN_PASSWORD=Admin1234!
# STUDENT_DEFAULT_PASSWORD=Student1234!

# Error Monitoring (Sentry)
# SENTRY_DSN=https://key@oXXX.ingest.sentry.io/project
# NEXT_PUBLIC_SENTRY_DSN=https://key@oXXX.ingest.sentry.io/project

# URLs
NEXT_PUBLIC_SITE_URL=http://localhost:3000
SITE_URL=http://localhost:3000
GOTRUE_EXTERNAL_GOOGLE_REDIRECT_URI=http://localhost:3000/auth/v1/callback
